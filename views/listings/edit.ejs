<% layout('layouts/boilerplate') %>
<body>
   <div class="edit-container">
    <h3>Edit Listing</h3>
    <hr>
    <br>
    <form action="/listings/<%= edit_listing.id %>?_method=PUT" novalidate enctype="multipart/form-data" class="needs-validation" method="POST">
    <div class="mb-3 g-3 row ">
    <div class="mb-3">
        <label class="form-label" for="title">Title:</label>
        <input type="text" id="title" class="form-control"  name="listing[title]" value="<%= edit_listing.title %>" required><br>
        <div class="invalid-feedback text-white">
            Please Enter  Title!
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label" for="description">Description:</label>
        <textarea id="description" class="form-control" rows="5" column="100" name="listing[description]" required><%= edit_listing.description %></textarea><br>
        <div class="invalid-feedback text-white">
            Please Enter  Description!
        </div>
    </div>
    <div class="mb-3">
        <label for="image" class="form-label">Current Image</label>
        <img src="<%=edit_listing.image.url%>" class="img-fluid ${3|rounded-top,rounded-right,rounded-bottom,rounded-left,rounded-circle,|}" alt="">
    </div>

    <div class="mb-3">
    <label for="image" class="form-label">Upload Image</label>
    <input type="file" name="listing[image]"  class="form-control" id="image" >
        <div class="invalid-feedback text-white">
            Please upload Image!
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label" for="price">Price:</label>
        <input type="number" id="price" class="form-control" name="listing[price]" value="<%= edit_listing.price %>" required><br>
        <div class="invalid-feedback text-white">
            Please Enter   Price!
        </div>
    </div>
    <div class="mb-3 row">
    <div class="col">
        <label class="form-label" for="location">Location:</label>
        <input type="text" id="location" class="form-control" name="listing[location]" value="<%= edit_listing.location %>" required><br>
        <div class="invalid-feedback text-white">
            Please Enter Location!
        </div>
    </div>
    <div class="col">
        <label class="form-label" for="country">Country:</label>
        <input type="text" id="country" class="form-control" name="listing[country]" value="<%= edit_listing.country %>" required><br>
        <div class="invalid-feedback text-white">
            Please Enter  Country!
        </div>
    </div>
    </div>
   
        <button type="submit">Update Listing</button>
    </form>
    </div>
</body>
